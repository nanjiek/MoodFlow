PROJECT_NAME=MoodFlow
TZ=Asia/Hong_Kong

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=moodflow
MYSQL_USER=moodflow
MYSQL_PASSWORD=moodflow
MYSQL_ROOT_PASSWORD=moodflow_root

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DJANGO_SETTINGS_MODULE=moodflow_backend.settings
DJANGO_SECRET_KEY=change-me-in-local-env
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

MODEL_SERVICE_HOST=0.0.0.0
MODEL_SERVICE_PORT=8010
MODEL_SERVICE_URL=http://model-service:8010

DATA_DIR=/app/data
MODEL_DIR=/app/model_service/artifacts/baseline
